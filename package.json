{
  "name": "@urban/dotai",
  "version": "0.0.0",
  "bin": {
    "dotai": "./src/cli/main.ts"
  },
  "files": [
    "src/**/*.ts"
  ],
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts"
  },
  "scripts": {
    "check": "bun run lint && bun run typecheck && bun run test",
    "lint": "oxfmt && oxlint --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@effect/language-service": "^0.84.0",
    "@effect/vitest": "4.0.0-beta.46",
    "@types/node": "^25.6.0",
    "effect": "4.0.0-beta.46",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "oxfmt": "0.43.0",
    "oxlint": "1.58.0",
    "typescript": "latest",
    "vitest": "4.0.18"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxfmt",
      "oxlint --fix"
    ],
    "*.{css,html,json,jsonc,md,mdx,yml,yaml}": [
      "oxfmt"
    ]
  },
  "engines": {
    "node": ">= 24.12.0"
  },
  "packageManager": "bun@1.3.5"
}
